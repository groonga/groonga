table_create Data TABLE_HASH_KEY ShortText

load --table Data
[
{"_key": "key"}
]

select Data --filter 'between([17, 170, 1700], 18, "include", 20, "exclude")'
select Data --filter 'between([18, 180, 1800], 18, "include", 20, "exclude")'
select Data --filter 'between([19, 190],       18, "include", 20, "exclude")'
select Data --filter 'between([20],            18, "include", 20, "exclude")'
select Data --filter 'between([21, 210, 2100], 18, "include", 20, "exclude")'
