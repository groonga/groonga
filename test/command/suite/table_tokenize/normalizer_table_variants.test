table_create Normalizations TABLE_PAT_KEY ShortText
column_create Normalizations normalized COLUMN_SCALAR ShortText

load --table Normalizations
[
{"_key": "齋", "normalized": "斉"},
{"_key": "斎", "normalized": "斉"},
{"_key": "渡邉", "normalized": "渡辺"},
{"_key": "渡邊", "normalized": "渡辺"},
{"_key": "渡部", "normalized": "渡辺"}
]

table_create Terms TABLE_PAT_KEY ShortText \
  --default_tokenizer TokenBigram \
  --normalizers 'NormalizerTable("normalized", "Normalizations.normalized")'

table_tokenize Terms "斉藤" \
  --mode ADD \
  --with_normalizer_table_variants yes

table_tokenize Terms "渡辺" \
  --mode ADD \
  --with_normalizer_table_variants yes

table_create ColumnNormalizations TABLE_NO_KEY
column_create ColumnNormalizations target COLUMN_SCALAR ShortText
column_create ColumnNormalizations normalized COLUMN_SCALAR ShortText

table_create Targets TABLE_PAT_KEY ShortText
column_create Targets column_normalizations_target \
  COLUMN_INDEX ColumnNormalizations target

load --table ColumnNormalizations
[
{"target": "齋", "normalized": "斉"},
{"target": "斎", "normalized": "斉"}
]

table_create ColumnTerms TABLE_PAT_KEY ShortText \
  --default_tokenizer TokenBigram \
  --normalizers 'NormalizerTable("normalized", \
                                 "ColumnNormalizations.normalized", \
                                 "target", \
                                 "target")'

table_tokenize ColumnTerms "斉藤" \
  --mode ADD \
  --with_normalizer_table_variants yes
